# Google Gemini — script parsing & mood analysis (FREE at aistudio.google.com)
GEMINI_API_KEY=your_gemini_api_key

# Pexels — b-roll video & image search (free at pexels.com/api)
PEXELS_API_KEY=your_pexels_api_key

# Freesound — sound effects (free at freesound.org/apiv2)
FREESOUND_API_KEY=your_freesound_api_key

# Pixabay — background music (free at pixabay.com/api/docs)
PIXABAY_API_KEY=your_pixabay_api_key

# ElevenLabs — voiceover generation (free tier at elevenlabs.io)
ELEVENLABS_API_KEY=your_elevenlabs_api_key

# OpenAI — Whisper word-level caption sync (optional, add when ready)
# Without this, captions still work using estimated timing
OPENAI_API_KEY=your_openai_api_key

# -----------------------------------------------------------------------
# Twitter / X — auto-reply bot (developer.twitter.com)
# Requires Basic tier ($100/mo) or above for read + write access
# -----------------------------------------------------------------------
TWITTER_BEARER_TOKEN=your_bearer_token
TWITTER_API_KEY=your_api_key
TWITTER_API_SECRET=your_api_secret
TWITTER_ACCESS_TOKEN=your_access_token
TWITTER_ACCESS_TOKEN_SECRET=your_access_token_secret
